# Copy this file to .env and fill in your values

# Server (for QR links and check-in URL)
BASE_URL=http://localhost:3001

# Supabase (attendees stored here; required for registration + check-in)
SUPABASE_URL=https://YOUR_SUPABASE_URL.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Auth (used to sign session JWT cookies)
JWT_SECRET=YOUR_JWT_SECRET

# Google OAuth (for "Continue with Google")
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Staff/scanner access (protects ticket scanning API)
SCANNER_API_KEY=YOUR_SCANNER_API_KEY

# Google Sheet (optional; see README for setup)
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Email – required for sending QR ticket to user when they register (Gmail example)
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password

# Event name (used in emails)
EVENT_NAME=My Awesome Event

# If you configure a Supabase Edge Function to send the ticket email, set this to "true"
# to skip sending from the Node server (the function/trigger will handle it):
# EMAIL_VIA_SUPABASE=true

# Admin API key – required for accessing /admin and /api/admin/events from the dashboard.
# Use a strong random string and keep it secret.
ADMIN_API_KEY=YOUR_ADMIN_API_KEY

